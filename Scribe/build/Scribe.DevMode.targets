<Project>
  <!--
      Scribe Dev Mode: automatic local NuGet package version override.

      When developing a framework (e.g. Hermetic) alongside a consuming project (e.g. Mish),
      you want the consumer to automatically pick up locally-built packages instead of the
      published NuGet versions. This target automates that by generating a
      Directory.Packages.Local.props file after every Pack, containing the exact version
      that was just built.

      ── Configuration ──────────────────────────────────────────────────────────

      Set these properties in your Directory.Build.props or Directory.Build.targets:

        ScribeDevPropsPath        Where to write the generated file.
                                  Default: $(MSBuildThisFileDirectory)..\Directory.Packages.Local.props
                                  (one directory above the repo root — shared between sibling repos).

        ScribeDevPackageNames     Semicolon-separated list of package names to include.
                                  Example: MyFramework;MyFramework.Generators

        ScribeDevTriggerProject   The project name that triggers generation (runs once, not per-project).
                                  Should be the "main" packable project in your solution.
                                  Example: MyFramework

      ── Consumer-side setup ────────────────────────────────────────────────────

      In the consuming project's Directory.Packages.props:

        <Import Project="path/to/Directory.Packages.Local.props"
                Condition="'$(UseLocal...)' == 'true'
                           and Exists('path/to/Directory.Packages.Local.props')" />

      In the consuming project's Directory.Build.props:

        <PropertyGroup Condition="'$(UseLocal...)' == 'true'">
          <RestoreAdditionalProjectSources>
            path/to/framework/.artifacts/packages;$(RestoreAdditionalProjectSources)
          </RestoreAdditionalProjectSources>
        </PropertyGroup>

      The generated file should be gitignored in both repos.
  -->

  <Target
    Name="ScribeGenerateLocalDevProps"
    AfterTargets="Pack"
    Condition="'$(ScribeDevTriggerProject)' != ''
                     and '$(MSBuildProjectName)' == '$(ScribeDevTriggerProject)'
                     and '$(ScribeDevPackageNames)' != ''"
  >
    <PropertyGroup>
      <_ScribeVersion>$(NuGetPackageVersion)</_ScribeVersion>
      <_ScribeVersion Condition="'$(_ScribeVersion)' == ''">$(PackageVersion)</_ScribeVersion>
      <_ScribeDevPropsPath Condition="'$(ScribeDevPropsPath)' == ''"
        >$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\Directory.Packages.Local.props'))</_ScribeDevPropsPath
      >
      <_ScribeDevPropsPath Condition="'$(ScribeDevPropsPath)' != ''"
        >$([System.IO.Path]::GetFullPath('$(ScribeDevPropsPath)'))</_ScribeDevPropsPath
      >
    </PropertyGroup>

    <!-- Build the package version lines from the semicolon-separated list. -->
    <ItemGroup>
      <_ScribeDevPackage Include="$(ScribeDevPackageNames)" />
    </ItemGroup>

    <ItemGroup>
      <_ScribeDevLine Include="&lt;Project&gt;" />
      <_ScribeDevLine Include="  &lt;!-- Auto-generated by Scribe Dev Mode — do not edit. Rebuild the framework to refresh. --&gt;" />
      <_ScribeDevLine Include="  &lt;ItemGroup&gt;" />
      <_ScribeDevLine Include="    &lt;PackageVersion Update=&quot;%(_ScribeDevPackage.Identity)&quot; Version=&quot;$(_ScribeVersion)&quot; /&gt;" />
      <_ScribeDevLine Include="  &lt;/ItemGroup&gt;" />
      <_ScribeDevLine Include="&lt;/Project&gt;" />
    </ItemGroup>

    <WriteLinesToFile
      File="$(_ScribeDevPropsPath)"
      Lines="@(_ScribeDevLine)"
      Overwrite="true"
      Encoding="UTF-8"
    />
    <Message
      Text="[Scribe] Dev props → $(_ScribeDevPropsPath) ($(_ScribeVersion))"
      Importance="high"
    />
  </Target>
</Project>
