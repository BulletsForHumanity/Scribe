<Project>
  <!--
      Scribe Local Development — Property Definitions (Early Phase)

      Per-project local NuGet development: each producer declares its own name
      via $(ScribesName), and activates "producer mode" when a sentinel file
      '.$(ScribesName).user' or '.$(ScribesName).local' exists in $(ScribeRoot).
      Consumer-side infrastructure activates whenever *any* such suffix sentinel
      is present.

      ── Setup ──────────────────────────────────────────────────────────────

      1. Set $(ScribeRoot) to the shared workspace root (parent of all sibling
         repos) in your Directory.Build.props BEFORE importing this file.

      2. Set $(ScribesName) to your producer name (e.g. 'Scribe', 'Hermetic')
         in your Directory.Build.props BEFORE importing this file. Omit for
         pure consumers (e.g. Mish).

      3. Import this file in your Directory.Build.props:
           <Import Project="path/to/Scribe.LocalDev.props" Condition="Exists(...)" />

      ── Activation ─────────────────────────────────────────────────────────

      Producer mode (auto-pack, timestamped versions, override-file generation):
        Create EITHER '.$(ScribesName).user' OR '.$(ScribesName).local' in
        $(ScribeRoot), e.g. '.hermetic.user' or '.hermetic.local'. Both forms
        are supported: '.user' follows the .NET convention (matches
        VisualStudio.gitignore's '*.user' rule out of the box); '.local' reads
        more naturally and matches the JS ecosystem (Vite, Next.js). Pick
        whichever you prefer — either activates. Lowercase is canonical;
        Windows matches case-insensitively, Linux does not.

      Consumer mode (local package source, import overrides from artifacts):
        Activates when ANY '.*.user' or '.*.local' sentinel exists in
        $(ScribeRoot), or when $(IsLocalScribe) is set true via CLI /
        Directory.Build.props.

      ── Producer Set ────────────────────────────────────────────────────

      Every project whose Directory.Build.props sets $(ScribesName) is part
      of that producer's set. When the sentinel is active, every packable
      project in the set auto-packs and emits its own override file. This
      supports multi-package producers (e.g. Scribe ships both
      BulletsForHumanity.Scribe and BulletsForHumanity.Scribe.Sdk).

      ── Provides ─────────────────────────────────────────────────────────

        $(IsLocalScribe)       'true' when any local sentinel is active
                               (umbrella flag — governs consumer-side infra).
        $(IsLocalProducer)     'true' when THIS project's '.$(ScribesName).user'
                               or '.$(ScribesName).local' sentinel exists
                               (applies to every project in the set — governs
                               auto-pack and override-file emission).
        $(ScribeArtifactsDir)  $(ScribeRoot)\.artifacts\
        $(ScribePackagesDir)   $(ScribeArtifactsDir)packages\

      ── Override Files ───────────────────────────────────────────────────

      Each packable project in producer mode emits:
        $(ScribeArtifactsDir)$(PackageId).Directory.Packages.targets
      containing a PackageVersion Update entry pinning its PackageId to the
      just-built timestamped version. Consumers import all such files via
      wildcard in Scribe.LocalDev.targets. When the sentinel is removed, each
      project cleans up its own override file and stale -dev.* packages.
  -->

  <!-- ── Import Guard ──────────────────────────────────────────────────── -->
  <!-- Prevent double-import when both a NuGet package and a direct file import
       bring in this file (e.g. Mish gets it from Hermetic NuGet AND from
       the sibling Scribe repo). -->
  <PropertyGroup Condition="'$(_ScribeLocalDevImported)' == 'true'">
    <_ScribeLocalDevSkip>true</_ScribeLocalDevSkip>
  </PropertyGroup>
  <PropertyGroup Condition="'$(_ScribeLocalDevImported)' != 'true'">
    <_ScribeLocalDevImported>true</_ScribeLocalDevImported>
  </PropertyGroup>

  <!-- ── Typo Tolerance: $(ScribeName) → $(ScribesName) ─────────────────── -->
  <!-- The canonical property is $(ScribesName). If the user wrote the
       non-possessive form $(ScribeName), forward it. Canonical wins when
       both are set. -->
  <PropertyGroup Condition="'$(ScribesName)' == '' and '$(ScribeName)' != ''">
    <ScribesName>$(ScribeName)</ScribesName>
  </PropertyGroup>

  <!-- ── Umbrella Sentinel Scan (any .*.user / .*.local) ────────────────── -->
  <!-- Any '.*.user' or '.*.local' file at $(ScribeRoot) flips $(IsLocalScribe) on.
       This governs consumer-side infrastructure: NuGet source registration
       and version-override imports.

       NOTE: MSBuild forbids @(ItemList) references inside Condition attributes
       (MSB4099). Project the ItemGroup into a property first, then condition
       on the property. -->
  <ItemGroup Condition="'$(_ScribeLocalDevSkip)' != 'true' and '$(ScribeRoot)' != ''">
    <_ScribeLocalSentinel Include="$(ScribeRoot)\.*.user" />
    <_ScribeLocalSentinel Include="$(ScribeRoot)\.*.local" />
  </ItemGroup>
  <PropertyGroup Condition="'$(_ScribeLocalDevSkip)' != 'true'">
    <_ScribeLocalSentinelList>@(_ScribeLocalSentinel)</_ScribeLocalSentinelList>
  </PropertyGroup>
  <PropertyGroup Condition="'$(_ScribeLocalDevSkip)' != 'true'
                            and '$(IsLocalScribe)' != 'true'
                            and '$(_ScribeLocalSentinelList)' != ''">
    <IsLocalScribe>true</IsLocalScribe>
  </PropertyGroup>

  <!-- ── Per-Project Producer Sentinel ─────────────────────────────────── -->
  <!-- Activates producer mode for the project that declares $(ScribesName).
       Matches EITHER '.$(ScribesName).user' OR '.$(ScribesName).local'
       (lowercased). Both forms are supported — pick whichever you prefer. -->
  <PropertyGroup Condition="'$(_ScribeLocalDevSkip)' != 'true' and '$(ScribesName)' != '' and '$(ScribeRoot)' != ''">
    <_ScribeProducerBase>$(ScribeRoot)\.$(ScribesName.ToLowerInvariant())</_ScribeProducerBase>
  </PropertyGroup>
  <PropertyGroup Condition="'$(_ScribeLocalDevSkip)' != 'true'
                            and '$(IsLocalProducer)' != 'true'
                            and '$(_ScribeProducerBase)' != ''
                            and (Exists('$(_ScribeProducerBase).user') or Exists('$(_ScribeProducerBase).local'))">
    <IsLocalProducer>true</IsLocalProducer>
  </PropertyGroup>

  <!-- ── Path Setup ──────────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(_ScribeLocalDevSkip)' != 'true' and '$(IsLocalScribe)' == 'true' and '$(ScribeRoot)' != ''">
    <ScribeArtifactsDir>$(ScribeRoot)\.artifacts\</ScribeArtifactsDir>
    <ScribePackagesDir>$(ScribeArtifactsDir)packages\</ScribePackagesDir>
    <!-- Register the local packages directory as a NuGet source so restore finds them. -->
    <RestoreAdditionalProjectSources>
      $(RestoreAdditionalProjectSources);$(ScribePackagesDir)
    </RestoreAdditionalProjectSources>
  </PropertyGroup>

  <!-- ── Auto-Pack (producer mode) ─────────────────────────────────────── -->
  <!-- Every packable project in the producer set auto-packs when the sentinel
       is active. A project is "in the set" if its Directory.Build.props set
       $(ScribesName) — this is the same gate used for sentinel detection.
       Output is redirected to the shared packages directory so sibling
       consumers can resolve from it via $(ScribePackagesDir).

       IsPackable=false (Companions, Meta projects, tests) opts the project out
       of pack-on-build; only packable producers ship nupkgs. -->
  <PropertyGroup
    Condition="'$(_ScribeLocalDevSkip)' != 'true'
               and '$(IsLocalProducer)' == 'true'
               and '$(ScribesName)' != ''"
  >
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageOutputPath>$(ScribePackagesDir)</PackageOutputPath>
  </PropertyGroup>

  <!-- NOTE: Per-PackageId override files ($(PackageId).Directory.Packages.targets)
       are written from Scribe.LocalDev.targets, not here. They contain
       PackageVersion Update items that must be evaluated AFTER
       Directory.Packages.props declares the initial PackageVersion Include
       items. -->
</Project>
