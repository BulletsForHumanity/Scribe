<Project>
  <!--
      Scribe Local Development — Build Targets (Late Phase)

      When $(IsLocalScribe) is 'true' and the project is packable:
        1. Auto-packs the project after build (incremental — skips if the DLL hasn't changed).
        2. Generates a version override file so consumers resolve the locally-built package.

      ── Configuration ──────────────────────────────────────────────────────

      Set these properties in your Directory.Build.targets BEFORE importing this file:

        $(ScribeLocalDevTriggerProject)  The MSBuild project name that triggers override file
                                         generation. Should be the main packable project.
                                         Example: BFH.Hermetic

        $(ScribeLocalDevPackageNames)    Semicolon-separated NuGet package IDs to include
                                         in the override file.
                                         Example: BFH.Hermetic

        $(ScribeLocalDevOverrideName)    File name prefix for the override file.
                                         Defaults to $(ScribeLocalDevTriggerProject).
                                         Output: $(ScribeArtifactsDir)<Name>.Directory.Packages.targets
  -->

  <!-- ── Import Version Override Files ──────────────────────────────────── -->
  <!--
      Each producer solution (Scribe, Hermetic, etc.) generates an override file:
        $(ScribeArtifactsDir)/<Name>.Directory.Packages.targets
      containing PackageVersion Update entries for locally-built packages.
      The wildcard import picks up all of them.

      This MUST live in .targets (not .props) because PackageVersion Update items
      must be evaluated AFTER Directory.Packages.props declares the initial
      PackageVersion Include items. .targets files are imported after .props.
  -->
  <Import
    Project="$(ScribeArtifactsDir)*.Directory.Packages.targets"
    Condition="'$(IsLocalScribe)' == 'true'
               and '$(ScribeArtifactsDir)' != ''
               and Exists('$(ScribeArtifactsDir)')"
  />

  <PropertyGroup Condition="'$(IsLocalScribe)' == 'true'">
    <ScribeLocalDevOverrideName
      Condition="'$(ScribeLocalDevOverrideName)' == ''"
      >$(ScribeLocalDevTriggerProject)</ScribeLocalDevOverrideName
    >
  </PropertyGroup>

  <!-- ── Auto-Pack ────────────────────────────────────────────��─────────── -->
  <!--
      Runs after Build for every packable project in Local Scribe mode.
      Uses a sentinel file for incrementality: re-packs only when the output
      assembly has changed (source was modified or a rebuild was forced).
  -->
  <!--
      Auto-pack: enables GeneratePackageOnBuild for the trigger project when in
      Local Scribe mode, and redirects output to the shared packages directory.
      This piggybacks on the SDK's built-in pack-on-build mechanism, avoiding
      circular dependencies and NoBuild propagation issues.
  -->

  <!-- ── Override File Generation ──────────────────────────────────────── -->
  <!--
      Runs after auto-pack on the trigger project only. Generates a
      .Directory.Packages.targets file that the consumer's Scribe.LocalDev.props
      imports via wildcard. Contains PackageVersion overrides for all configured
      package names, pointing to the exact version that was just built.
  -->
  <Target
    Name="_ScribeLocalDevOverride"
    AfterTargets="Pack"
    Condition="'$(IsLocalScribe)' == 'true'
               and '$(MSBuildProjectName)' == '$(ScribeLocalDevTriggerProject)'
               and '$(ScribeLocalDevPackageNames)' != ''"
  >
    <PropertyGroup>
      <_ScribeDevVersion>$(NuGetPackageVersion)</_ScribeDevVersion>
      <_ScribeDevVersion Condition="'$(_ScribeDevVersion)' == ''">$(PackageVersion)</_ScribeDevVersion>
      <_ScribeDevOverridePath>$(ScribeArtifactsDir)$(ScribeLocalDevOverrideName).Directory.Packages.targets</_ScribeDevOverridePath>
    </PropertyGroup>

    <ItemGroup>
      <_ScribeDevPackage Include="$(ScribeLocalDevPackageNames)" />
    </ItemGroup>

    <ItemGroup>
      <_ScribeDevLine Include="&lt;Project&gt;" />
      <_ScribeDevLine Include="  &lt;!-- Auto-generated by Scribe LocalDev — do not edit. Rebuild the producer to refresh. --&gt;" />
      <_ScribeDevLine Include="  &lt;ItemGroup&gt;" />
      <_ScribeDevLine Include="    &lt;PackageVersion Update=&quot;%(_ScribeDevPackage.Identity)&quot; Version=&quot;$(_ScribeDevVersion)&quot; /&gt;" />
      <_ScribeDevLine Include="  &lt;/ItemGroup&gt;" />
      <_ScribeDevLine Include="&lt;/Project&gt;" />
    </ItemGroup>

    <MakeDir Directories="$(ScribeArtifactsDir)" />
    <WriteLinesToFile
      File="$(_ScribeDevOverridePath)"
      Lines="@(_ScribeDevLine)"
      Overwrite="true"
      Encoding="UTF-8"
    />
    <Message
      Text="[Scribe] Override → $(_ScribeDevOverridePath) ($(_ScribeDevVersion))"
      Importance="high"
    />
  </Target>
</Project>
