<Project>
  <!--
      Scribe Local Development — Build Targets (Late Phase)

      Producer responsibilities (when $(IsLocalProducer) is 'true'):
        1. Auto-pack via $(GeneratePackageOnBuild) set in Scribe.LocalDev.props.
        2. Emit a version override file $(ScribesName).Directory.Packages.targets
           listing locally-built package IDs at the timestamped dev version.

      Producer cleanup (when $(IsLocalProducer) is 'false' but this project
      declares $(ScribesName)):
        1. Delete its own stale override file (if any).
        2. Delete its own stale -dev.* packages from $(ScribePackagesDir).
        This keeps the shared artifacts folder from accumulating forever.

      Consumer responsibilities (when $(IsLocalScribe) is 'true'):
        1. Import all *.Directory.Packages.targets from $(ScribeArtifactsDir)
           so PackageVersion references get overridden to the local builds.

      ── Configuration ──────────────────────────────────────────────────────

      Set this property in your Directory.Build.props BEFORE importing
      Scribe.LocalDev.props:

        $(ScribesName)                   Producer project name. Used for:
                                          • sentinel detection: '.$(ScribesName).scribe'
                                          • auto-pack trigger: $(MSBuildProjectName) == $(ScribesName)
                                          • override file name: $(ScribesName).Directory.Packages.targets
                                         Example: Hermetic

      The override file's <PackageVersion Update> entry is derived automatically
      from the trigger project's $(PackageId). Under the Scribe.Sdk Library +
      Companion model only the Library project produces a nupkg (companions are
      embedded), so a single PackageId is sufficient.
  -->

  <!-- ── Import Guard ──────────────────────────────────────────────────── -->
  <!-- Prevent double-import when both a NuGet package and a direct file import
       bring in this file (mirrors the guard in Scribe.LocalDev.props). -->
  <PropertyGroup Condition="'$(_ScribeLocalDevTargetsImported)' == 'true'">
    <_ScribeLocalDevTargetsSkip>true</_ScribeLocalDevTargetsSkip>
  </PropertyGroup>
  <PropertyGroup Condition="'$(_ScribeLocalDevTargetsImported)' != 'true'">
    <_ScribeLocalDevTargetsImported>true</_ScribeLocalDevTargetsImported>
  </PropertyGroup>

  <!-- ── Import Version Override Files (consumer side) ──────────────────── -->
  <!--
      Each active producer (Scribe, Hermetic, ...) emits:
        $(ScribeArtifactsDir)/$(ScribesName).Directory.Packages.targets
      containing PackageVersion Update entries for locally-built packages.
      The wildcard import picks up files only from producers currently in
      producer mode (inactive producers clean up their own files).

      This MUST live in .targets (not .props) because PackageVersion Update
      items must be evaluated AFTER Directory.Packages.props declares the
      initial PackageVersion Include items. .targets files are imported after
      .props.
  -->
  <Import
    Project="$(ScribeArtifactsDir)*.Directory.Packages.targets"
    Condition="'$(_ScribeLocalDevTargetsSkip)' != 'true'
               and '$(IsLocalScribe)' == 'true'
               and '$(ScribeArtifactsDir)' != ''
               and Exists('$(ScribeArtifactsDir)')"
  />

  <!-- ── Local Pack Version Stamping ─────────────────────────────────── -->
  <!--
      Append a unique '-dev.{stamp}' suffix to the package version on every
      local pack (sentinel-driven producer mode OR Meta auto-pack). NuGet
      caches by version string, so without a fresh stamp every time, an
      in-place rebuild whose version is unchanged (NBGV's commit hash for
      committed-with-no-changes, or the bare default 1.0.0 when NBGV isn't
      in play) would silently serve stale cached bits to consumers.

      Format: '{SemVer}-dev.yyyyMMdd-HHmmss-fff' (UTC, millisecond precision).
      The stamp dashes are cosmetic — two builds in the same second still
      differ on the trailing milliseconds.

      Any pre-existing prerelease suffix (e.g. NBGV's '-g{hash}', or
      '-pre+meta') is stripped before re-attaching '-dev.{stamp}' so the
      version stays a clean {Major.Minor.Patch}-dev.{stamp} regardless of
      where the base version came from. NBGV is supported but not required
      — without NBGV the base is the project's $(VersionPrefix) (default
      '1.0.0').

      Runs BEFORE _GenerateNuspec (Pack reads $(PackageVersion) there) and
      before the override-file emitters in this same .targets file plus
      Scribe.Sdk's _ScribeSdkMetaOverride. The override emitter's
      $(NuGetPackageVersion) is set by NuGet from $(PackageVersion), so
      updating $(PackageVersion) here ensures the override file pins the
      same timestamped version the nupkg was built with.

      Idempotent: re-entry that sees a '-dev.' suffix already in place
      is a no-op (guarded via the target Condition).
  -->
  <!-- No _ScribeLocalDevTargetsSkip check here: when this file is imported via
       both Sdk.targets and Directory.Build.targets, MSBuild emits "Overriding
       target ..." — the second declaration replaces the first. Both copies have
       identical content, so a single execution of the surviving copy is correct
       and sufficient. (The skip flag exists to silence duplicate output from
       PropertyGroups, not to neutralise targets.) -->
  <Target
    Name="_ScribeLocalDevStampVersion"
    AfterTargets="GetBuildVersion"
    BeforeTargets="Build;GenerateNuspec;Pack;_ScribeLocalDevOverride;_ScribeSdkMetaOverride"
    Condition="'$(_ScribeAutoStampVersion)' == 'true'
               and '$(IsPackable)' != 'false'
               and !$(NuGetPackageVersion.Contains('-dev.'))
               and !$(PackageVersion.Contains('-dev.'))"
  >
    <PropertyGroup>
      <_ScribeDevStamp>$([System.DateTime]::UtcNow.ToString("yyyyMMdd-HHmmss-fff"))</_ScribeDevStamp>
      <!-- Strip any pre-existing prerelease suffix (NBGV '-g{hash}',
           '-pre+meta', anything dash-led) so the result is always
           {Major.Minor.Patch}-dev.{stamp}. Use NuGetPackageVersion as the
           source of truth (NBGV sets it in GetBuildVersion); fall back to
           PackageVersion or VersionPrefix when NBGV isn't in play. -->
      <_ScribeBaseVersion>$([System.Text.RegularExpressions.Regex]::Replace($(NuGetPackageVersion), '-.*$', ''))</_ScribeBaseVersion>
      <_ScribeBaseVersion Condition="'$(_ScribeBaseVersion)' == ''">$([System.Text.RegularExpressions.Regex]::Replace($(PackageVersion), '-.*$', ''))</_ScribeBaseVersion>
      <_ScribeBaseVersion Condition="'$(_ScribeBaseVersion)' == ''">$(VersionPrefix)</_ScribeBaseVersion>
      <!-- Update every consumer of "the package's version": NuGetPackageVersion
           feeds the override-file emitter, PackageVersion feeds Pack's nuspec,
           Version feeds AssemblyInfo / SemVer comparisons. All must agree. -->
      <NuGetPackageVersion>$(_ScribeBaseVersion)-dev.$(_ScribeDevStamp)</NuGetPackageVersion>
      <PackageVersion>$(NuGetPackageVersion)</PackageVersion>
      <Version>$(NuGetPackageVersion)</Version>
    </PropertyGroup>
    <Message
      Text="[Scribe] Stamped local pack version → $(NuGetPackageVersion)"
      Importance="high"
    />
  </Target>

  <!-- ── Override File Generation (producer mode) ──────────────────────── -->
  <!--
      Runs after Pack on every packable project in the producer set. Each
      project emits its own $(PackageId).Directory.Packages.targets file with
      a PackageVersion Update pinning its own PackageId to the just-built
      version. Consumers import all such files via wildcard.
  -->
  <Target
    Name="_ScribeLocalDevOverride"
    AfterTargets="Pack"
    Condition="'$(IsLocalProducer)' == 'true'
               and '$(ScribesName)' != ''
               and '$(PackageId)' != ''
               and '$(ScribeArtifactsDir)' != ''
               and '$(IsPackable)' != 'false'
               and '$(_IsScribeMeta)' != 'true'"
  >
    <PropertyGroup>
      <_ScribeDevVersion>$(NuGetPackageVersion)</_ScribeDevVersion>
      <_ScribeDevVersion Condition="'$(_ScribeDevVersion)' == ''">$(PackageVersion)</_ScribeDevVersion>
      <_ScribeDevOverridePath>$(ScribeArtifactsDir)$(PackageId).Directory.Packages.targets</_ScribeDevOverridePath>
    </PropertyGroup>

    <ItemGroup>
      <_ScribeDevLine Include="&lt;Project&gt;" />
      <_ScribeDevLine Include="  &lt;!-- Auto-generated by Scribe LocalDev — do not edit. Rebuild the producer to refresh. --&gt;" />
      <_ScribeDevLine Include="  &lt;ItemGroup&gt;" />
      <_ScribeDevLine Include="    &lt;PackageVersion Update=&quot;$(PackageId)&quot; Version=&quot;$(_ScribeDevVersion)&quot; /&gt;" />
      <_ScribeDevLine Include="  &lt;/ItemGroup&gt;" />
      <_ScribeDevLine Include="&lt;/Project&gt;" />
    </ItemGroup>

    <MakeDir Directories="$(ScribeArtifactsDir)" />
    <WriteLinesToFile
      File="$(_ScribeDevOverridePath)"
      Lines="@(_ScribeDevLine)"
      Overwrite="true"
      Encoding="UTF-8"
    />
    <Message
      Text="[Scribe] Override → $(_ScribeDevOverridePath) ($(_ScribeDevVersion))"
      Importance="high"
    />
  </Target>

  <!-- ── Cleanup When Sentinel Is Removed ───────────────────────────────── -->
  <!--
      When a project in the producer set builds WITHOUT its '.$(ScribesName).scribe'
      sentinel, delete its own stale override file
      and stale -dev.* packages. Runs per-project (each project cleans up its
      own PackageId-keyed artifacts) so a newly-added project's artifacts get
      cleaned once it too builds sentinel-less.

      Safety: deletion is scoped to files matching this project's own
      $(PackageId) with a '-dev.' version suffix. Other producers' artifacts
      are untouched.
  -->
  <Target
    Name="_ScribeLocalDevCleanupStale"
    BeforeTargets="Build"
    Condition="'$(_ScribeLocalDevTargetsSkip)' != 'true'
               and '$(IsLocalProducer)' != 'true'
               and '$(ScribesName)' != ''
               and '$(PackageId)' != ''
               and '$(ScribeArtifactsDir)' != ''
               and Exists('$(ScribeArtifactsDir)')"
  >
    <PropertyGroup>
      <_ScribeCleanupOverride>$(ScribeArtifactsDir)$(PackageId).Directory.Packages.targets</_ScribeCleanupOverride>
    </PropertyGroup>

    <!-- Stale override file. -->
    <Delete
      Files="$(_ScribeCleanupOverride)"
      Condition="Exists('$(_ScribeCleanupOverride)')"
    />
    <Message
      Text="[Scribe] Cleanup → removed stale override $(_ScribeCleanupOverride)"
      Importance="high"
      Condition="Exists('$(_ScribeCleanupOverride)')"
    />

    <!-- Stale -dev.* packages keyed to this producer's PackageId. -->
    <ItemGroup>
      <_ScribeStalePackage Include="$(ScribePackagesDir)$(PackageId).*-dev.*.nupkg" />
      <_ScribeStalePackage Include="$(ScribePackagesDir)$(PackageId).*-dev.*.snupkg" />
    </ItemGroup>

    <Delete Files="@(_ScribeStalePackage)" Condition="'@(_ScribeStalePackage)' != ''" />
    <Message
      Text="[Scribe] Cleanup → removed %(_ScribeStalePackage.Filename)%(_ScribeStalePackage.Extension)"
      Importance="high"
      Condition="'@(_ScribeStalePackage)' != ''"
    />
  </Target>
</Project>
