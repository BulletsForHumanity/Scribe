<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>14</LangVersion>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IncludeSourceGeneratorAttributes>false</IncludeSourceGeneratorAttributes>
    <!--
        Scribe is a class library consumed by analyzer projects.
        It is NOT an analyzer itself — it provides shared source-generation utilities.
        Consuming analyzer packages must bundle the Scribe DLL alongside their own output
        (e.g. via CopyLocalLockFileAssemblies + custom packaging targets).
    -->
    <!-- Embed PDB directly so IDE tooling can step through Scribe source. -->
    <IncludeSymbols>false</IncludeSymbols>
    <DebugType>embedded</DebugType>
    <!-- NU5128: no DLL in lib/ — expected, Scribe is bundled into analyzer packages. -->
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <!-- Disable doc XML file — Scribe is bundled into analyzer assemblies, not consumed directly.
         The .xml file would otherwise be picked up as metadata by downstream references. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <PackageId>BulletsForHumanity.Scribe</PackageId>
    <Description>Fluent source-generation utilities for Roslyn incremental generators. Provides Quill (fluent source builder), naming helpers, XML doc extraction, and well-known BCL type constants.</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Scribe.Ink" />
    <InternalsVisibleTo Include="Scribe.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\LICENSE" Pack="true" PackagePath="" />
    <None Include="..\README.md" Pack="true" PackagePath="" />
    <!-- Ship LocalDev build infrastructure so consumers get it via NuGet.
         The BulletsForHumanity.Scribe.* wrappers are the NuGet auto-import entry points.
         The Scribe.LocalDev.* files contain the actual logic and are also importable
         directly from a sibling repo checkout. -->
    <None Include="build\BulletsForHumanity.Scribe.props" Pack="true" PackagePath="build" />
    <None Include="build\BulletsForHumanity.Scribe.targets" Pack="true" PackagePath="build" />
    <None Include="build\Scribe.LocalDev.props" Pack="true" PackagePath="build" />
    <None Include="build\Scribe.LocalDev.targets" Pack="true" PackagePath="build" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
  </ItemGroup>

  <!-- Scriptorium: build-time-only meta-generator. Emits Should*/Could*/ShouldNot*
       variants of each Must* primitive on ShapeBuilder. Never ships. -->
  <ItemGroup>
    <ProjectReference Include="..\Scribe.Scriptorium\Scribe.Scriptorium.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
